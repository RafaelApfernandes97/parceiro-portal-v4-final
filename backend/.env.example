# ════════════════════════════════════════════
# PORTAL DE PARCEIROS — MAIS CHAT TECNOLOGIA
# v2.0 — Segurança reforçada
# ════════════════════════════════════════════

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# MongoDB
MONGO_URI=mongodb://localhost:27017/parceiro-portal

# JWT — TROQUE EM PRODUÇÃO (mín 64 chars)
JWT_SECRET=GERE_UMA_CHAVE_DE_64_CHARS
JWT_EXPIRES_IN=7d

# SMTP — TROQUE A SENHA ANTES DE PRODUÇÃO (exposta em conversa)
SMTP_HOST=grid171.mailgrid.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=maischat@mais.chat
SMTP_PASS=TROQUE_AQUI
SMTP_FROM_NAME=Mais Chat Tecnologia
SMTP_FROM_EMAIL=maischat@mais.chat
ADMIN_EMAIL=admin@maischat.com

# D4Sign
D4SIGN_BASE_URL=https://secure.d4sign.com.br/api/v1
D4SIGN_TOKEN_API=seu_token_d4sign
D4SIGN_CRYPT_KEY=sua_crypt_key_d4sign
D4SIGN_SAFE_UUID=uuid_do_cofre_d4sign
D4SIGN_WEBHOOK_SECRET=seu_webhook_secret_d4sign

# External API — Chave primária e secundária para rotação
EXTERNAL_API_KEY_PRIMARY=GERE_UMA_CHAVE_UNICA
EXTERNAL_API_KEY_SECONDARY=mc_sk_disabled
EXTERNAL_API_KEY_EXPIRY=2027-01-01

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=20

# Admin Master
ADMIN_EMAIL_MASTER=admin@maischat.com
ADMIN_PASSWORD_MASTER=MaisChat@2025!
